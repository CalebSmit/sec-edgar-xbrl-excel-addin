# Compiled add-in artifacts (workspace-level, not for repo)
# Exception: dist/ folder contains the prebuilt release binary
*.xlsm
*.xlsx

# Exclude xlam everywhere EXCEPT the dist/ folder
*.xlam
!dist/*.xlam

# Excel temp files
~$*
*.tmp

# macOS
.DS_Store

# Windows
Thumbs.db
desktop.ini

# VBA export artifacts
*.frm
*.frx

# Python audit scripts (workspace only, not part of the add-in)
__pycache__/
*.pyc
